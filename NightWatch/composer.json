{
  "name": "nightwatch/webapp",
  "description": "NightWatch PHP/MySQL security writeup application",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-mysqli": "*",
    "ext-json": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*"
  },
  "autoload": {
    "psr-4": {
      "NightWatch\\": "src/NightWatch/"
    }
  },
  "scripts": {
    "lint:php": "find WebApp/functions DB -name '*.php' -print0 | xargs -0 -n1 php -l",
    "test": "php tests/run_tests.php"
  }
}
